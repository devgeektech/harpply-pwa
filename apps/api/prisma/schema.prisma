generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  // null until user completes set-password step
  createdAt DateTime @default(now())
  googleId  String?
  role      UserRole @default(user)

  // Auth
  token              String?     // current session token (jti); cleared on logout
  resetOtp           String?
  resetOtpExpires    DateTime?
  resetToken         String?
  resetTokenExpires  DateTime?
  emailVerified      Boolean  @default(false)
  emailVerificationToken String?

  // Onboarding - Identity / Profile
  fullName   String?
  age        Int?
  gender     Gender?
  profilePhotos  Json?    // array of S3 object keys (strings) for profile photos

  // Onboarding - Location
  latitude   Float?
  longitude  Float?
  location   String?   // display e.g. "Nashville, TN"
  locationEnabled Boolean? @default(false)

  // Onboarding - Bio / Story
  bio        String?

  // Onboarding - Faith & Lifestyle / Profile
  denomination     String?
  churchInvolvement    String?
  yearsInFaith         Int?
  churchAttendance     String?
  myFaithValues        Json?     // array of strings
  partnerValues        Json?     // array of strings
  smokingPreference    String?   // Never, Socially, Regularly
  alcoholPreference    String?   // Never, Socially, Regularly
  dietaryPreference    String?

  // Onboarding - Everyday life questions
  relationshipHistory   Json?     // array of strings
  haveChildren          Json?     // array of strings
  wantChildren          Json?     // array of strings
  openToPartnerWithChildren Json?     // array of strings
  freeTime              Json?     // array of strings
  musicTaste            Json?     // array of strings
  sportsPlayOrFollow    Json?     // array of strings
  fitnessLifestyle      Json?     // array of strings
  recharge              Json?     // array of strings
  communicationStyle    Json?     // array of strings
  favoriteFood          Json?     // array of strings
  travelerType          Json?     // array of strings
  travelStyle           Json?     // array of strings
  perfectNightIn        Json?     // array of strings
  showsOrMovies         Json?     // array of strings
  dayToDay              Json?     // array of strings
  
  biblicalPreferences   Json?     // map: question id -> selected option string

  onboardingCompleted  Boolean @default(false)

  @@schema("auth")
}

enum UserRole {
  admin
  user

  @@schema("auth")
}

enum Gender {
  male
  female
  other

  @@schema("auth")
}
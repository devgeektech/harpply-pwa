generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  resetOtp           String?
  resetOtpExpires    DateTime?
  resetToken         String?
  resetTokenExpires  DateTime?

  @@schema("auth")
}
# Copy this file to .env and fill in the values.
# Required for the API to start.

# PostgreSQL on port 5433 (run `pnpm dev` or `pnpm db` to start Docker db)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/harpply"

# Port the API listens on (optional, default 5000)
PORT=5000

# JWT secret for auth tokens (optional in dev, use a strong value in production)
JWT_SECRET="your-very-secure-secret-1234567890"

# Email verification: link in email points to your frontend verify-email page
# Local dev: http://localhost:3000
# Live server: set to your live frontend URL (e.g. https://harpply.com) so Brevo emails use the live link
FRONTEND_APP_URL=http://localhost:3000
# Optional: where to redirect after verify if using API redirect flow
FRONTEND_SET_PASSWORD_URL=http://localhost:3000/auth/set-password

# AWS S3 (common – used by all modules; each module has its own bucket env vars)
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Profile photos module (bucket: harpply; file URL: https://harpply.s3.ap-southeast-2.amazonaws.com/)
AWS_S3_BUCKET_PROFILE_PHOTOS=harpply
AWS_S3_PUBLIC_URL_PROFILE_PHOTOS=https://harpply.s3.ap-southeast-2.amazonaws.com
AWS_S3_KEY_PREFIX_PROFILE_PHOTOS=profile-photos

FIREBASE_PROJECT_ID=harpply
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@harpply.iam.gserviceaccount.com

# Google OAuth (server-side flow). Create a "Web application" client in Google Cloud Console.
# Add exactly this URL to "Authorised redirect URIs": http://localhost:5000/auth/google/callback
# For production, add your API base URL + /auth/google/callback and set GOOGLE_CALLBACK_URI to match.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Paste once only — a duplicated "GOCSPX-..." string causes token_exchange_failed.
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URI=http://localhost:5000/auth/google/callback

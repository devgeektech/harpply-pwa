# Copy this file to .env and fill in the values.
# Required for the API to start.

# PostgreSQL connection string (required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/harpply_db"

# Port the API listens on (optional, default 5000)
PORT=5000

# JWT secret for auth tokens (optional in dev, use a strong value in production)
JWT_SECRET="your-very-secure-secret-1234567890"
